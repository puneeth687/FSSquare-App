{
  "expo": {
    "name": "FS²",
    "slug": "FSSquared",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fsquared",
    "platforms": [
      "ios",
      "android"
    ],
    "android": {
      "package": "com.fssquared.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "fsquared",
              "host": "oauthredirect"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.fssquared.app"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
